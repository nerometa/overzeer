{
  "name": "overzeer",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @overzeer/db db:push",
    "db:studio": "turbo -F @overzeer/db db:studio",
    "db:generate": "turbo -F @overzeer/db db:generate",
    "db:migrate": "turbo -F @overzeer/db db:migrate",
    "db:local": "turbo -F @overzeer/db db:local",
    "db:seed": "turbo -F @overzeer/db db:seed",
    "db:reset": "turbo -F @overzeer/db db:reset",
    "test": "cd packages/api && bun test",
    "test:e2e": "cd apps/web && bun run test:e2e"
  },
  "dependencies": {
    "@overzeer/env": "workspace:*",
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "turbo": "^2.6.3",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.8"
}
