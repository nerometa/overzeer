{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/trpc": "^1.1.0",
    "@hono/trpc-server": "^0.4.0",
    "@overzeer/api": "workspace:*",
    "@overzeer/auth": "workspace:*",
    "@overzeer/db": "workspace:*",
    "@overzeer/env": "workspace:*",
    "@trpc/server": "^11.7.2",
    "better-auth": "^1.4.18",
    "dotenv": "^17.2.2",
    "elysia": "^1.4.21",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
