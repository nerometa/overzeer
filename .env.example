# =============================================================================
# Overzeer Environment Variables - Local Development
# =============================================================================
#
# Copy this file: cp .env.example .env
# Edit .env with your values
#
# =============================================================================

# -----------------------------------------------------------------------------
# BACKEND (Elysia) - Port 3000
# -----------------------------------------------------------------------------
NODE_ENV=development
SERVER_PORT=3000

# Database - SQLite file path (local)
DATABASE_URL=file:./backend/data/local.db

# Better Auth - Local development URL
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here-min-32-characters
BETTER_AUTH_URL=http://localhost:3000

# CORS - Local frontend URL
CORS_ORIGIN=http://localhost:3001

# -----------------------------------------------------------------------------
# FRONTEND (Next.js) - Port 3001
# -----------------------------------------------------------------------------
PORT=3001

# Backend URL for frontend to connect to
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
