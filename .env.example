# =============================================================================
# Overzeer Environment Variables
# =============================================================================
#
# BUILD TIME: Dummy values used during `docker build` (SKIP_DB_PUSH=1)
# RUN TIME: Real values loaded from this file via Docker Compose env_file
#
# Usage:
#   1. Copy: cp .env.example .env
#   2. Edit: Set your values below
#   3. Deploy: docker-compose up (loads .env automatically)
#
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001

# Public API URL (for Eden client in browser)
NEXT_PUBLIC_API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Database - SQLite file path
# -----------------------------------------------------------------------------
DATABASE_URL=file:./src/server/data/local.db

# -----------------------------------------------------------------------------
# Better Auth
# Generate secret: openssl rand -base64 32
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=your-secret-here-min-32-characters
BETTER_AUTH_URL=http://localhost:3001
