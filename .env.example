# =============================================================================
# Overzeer Environment Variables
# =============================================================================
#
# PRODUCTION SETUP:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values
# 3. Update the domain (overzeer.nerometa.dev) to your actual domain
#
# =============================================================================

# -----------------------------------------------------------------------------
# BACKEND (Elysia) - Port 3000
# -----------------------------------------------------------------------------
NODE_ENV=production
SERVER_PORT=3000

# Database - SQLite file path (inside Docker container)
DATABASE_URL=file:/app/data/local.db

# Better Auth - MUST be your public HTTPS domain
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here-min-32-characters
BETTER_AUTH_URL=https://overzeer.nerometa.dev

# CORS - MUST be your frontend's public HTTPS domain
CORS_ORIGIN=https://overzeer.nerometa.dev

# Frontend port
PORT=3001
